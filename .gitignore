# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/
build/
**/.angular/
*.tsbuildinfo

# Environment files (never commit real secrets; .env.example files are explicitly allowed)
.env
.env.*
!.env.example
!.env.*.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
logs/

# Test coverage
coverage/
**/coverage/

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# Lint/format caches
.eslintcache
.prettiercache

# Husky internals (regenerated by `npm install`'s prepare script — only
# .husky/pre-commit and .husky/commit-msg, the hook scripts themselves, are
# tracked)
.husky/_/

# AI coding assistant local session/runtime state
.claude/

# Temporary files
tmp/
temp/
*.tmp
