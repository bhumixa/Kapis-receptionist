# Optional overrides for infrastructure/docker-compose.yml's Postgres
# credentials — the compose file already has working defaults
# (kapis/kapis_dev_password/kapis_receptionist) for local development, so
# copying this file is only needed to change them. Place a copy at
# infrastructure/.env (docker compose auto-loads a .env next to the compose
# file) to take effect.
#
# Staging/production credentials are never committed — see
# docs/SYSTEM_ARCHITECTURE.md Section 10.6/9.5.

POSTGRES_USER=kapis
POSTGRES_PASSWORD=kapis_dev_password
POSTGRES_DB=kapis_receptionist
