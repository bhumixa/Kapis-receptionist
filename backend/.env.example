# Copy to .env for local development. Never commit a real .env file.
# See docs/SYSTEM_ARCHITECTURE.md Section 10.6 (Environment Variables).

# --- Application ---
NODE_ENV=development
PORT=3000
APP_NAME="Kapis Receptionist API"
CORS_ORIGIN=http://localhost:4200
LOG_LEVEL=debug

# --- PostgreSQL (docs/DATABASE_DESIGN.md, docs/PRISMA_SCHEMA.md) ---
DATABASE_URL="postgresql://kapis:kapis_dev_password@localhost:5432/kapis_receptionist?schema=public"

# --- Redis (docs/SYSTEM_ARCHITECTURE.md Section 11.3) ---
REDIS_URL="redis://localhost:6379"

# --- Auth (docs/AUTHENTICATION.md) ---
# Two independent secrets (SYSTEM_ARCHITECTURE.md Section 7.1/7.2): one signs
# the access-token JWT, the other peppers the refresh-token hash. Generate
# each with `openssl rand -base64 48` — never reuse a value between them or
# across environments.
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN_SECONDS=2592000

# --- Mail / Notifications (docs/AUTHENTICATION.md — Sprint 2.3 Account Security) ---
# Leave SMTP_HOST unset for local dev/CI: NotificationsService logs the email
# instead of sending it, so verification/reset flows still work with zero
# mail infrastructure.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM="no-reply@kapis-receptionist.example.com"
FRONTEND_URL=http://localhost:4200

# --- Login attempt tracking / temporary lockout (docs/AUTHENTICATION.md) ---
LOGIN_ATTEMPT_MAX=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=900

# --- Email verification / password reset token lifetimes ---
EMAIL_VERIFICATION_EXPIRES_IN_SECONDS=86400
PASSWORD_RESET_EXPIRES_IN_SECONDS=3600

# --- Authorization / RBAC (docs/adr/ADR-005-rbac.md) ---
# How long PermissionResolverService caches a role's resolved permission set
# in Redis. TTL-only invalidation this sprint — see the ADR for why.
RBAC_PERMISSION_CACHE_TTL_SECONDS=3600
