// Prisma schema — see docs/PRISMA_SCHEMA.md for the full design.
//
// Milestone 1: the "global reference data" migration batch (docs/
// PRISMA_SCHEMA.md Section 14.2, step 1) — Role, Permission, RolePermission,
// Plan.
//
// Milestone 2, Sprint 2.1.1 (Identity Foundation, docs/AUTH_SCHEMA_REVIEW.md,
// docs/adr/ADR-002-authentication-schema.md): User, UserRole, RefreshToken,
// EmailVerification, PasswordReset, plus a minimal Tenant (schema only — no
// TenantSettings/TenantFeature or Tenants-module business logic, those remain
// Milestone 3 scope) and TenantInvitation, pulled forward ahead of Milestone
// 3 specifically to unblock Sprint 2.2's invitation-acceptance endpoint.
//
// Every other domain's models are added in the milestone that implements
// them, each as its own migration, per the documented migration order.
// Relations to models that don't exist yet are deferred the same way —
// added to the *existing* model when the other side is introduced, never
// declared as a forward reference to a model that isn't in this file.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "relationJoins", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // btree_gist backs the Milestone 6 booking-conflict EXCLUDE constraint
  // (docs/adr/ADR-009-scheduling-engine.md, PRISMA_SCHEMA.md Section 14.4's
  // "booking conflict-prevention hardening" item) — declared here so
  // `prisma migrate dev` emits `CREATE EXTENSION IF NOT EXISTS btree_gist`
  // for us; the EXCLUDE constraint itself still needs a manual migration
  // edit, since Prisma has no declarative syntax for it.
  extensions = [pgcrypto, btree_gist]
}

// --- Enums (docs/PRISMA_SCHEMA.md Section 2) -------------------------------

enum RoleName {
  SUPER_ADMIN
  OWNER
  MANAGER
  STAFF
}

enum ActorType {
  USER
  AI
  SYSTEM
  CUSTOMER
}

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

// Milestone 6 (docs/adr/ADR-009-scheduling-engine.md): PENDING is reserved for
// a future AI-initiated booking flow (Milestone 8) that may need staff
// confirmation before a slot is held with full priority — every appointment
// created this milestone (manual, staff-entered) goes straight to CONFIRMED.
enum AppointmentStatus {
  PENDING
  CONFIRMED
  RESCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentHistoryAction {
  CREATED
  RESCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW
  MODIFIED
}

// --- Authentication Models (docs/PRISMA_SCHEMA.md Section 3) ---------------

model User {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String?    @db.Uuid
  email            String     @unique @db.VarChar(255)
  passwordHash     String?    @db.VarChar(255)
  firstName        String     @db.VarChar(100)
  lastName         String     @db.VarChar(100)
  googleId         String?    @unique @db.VarChar(255)
  isEmailVerified  Boolean    @default(false)
  isActive         Boolean    @default(true)
  lastLoginAt      DateTime?
  twoFactorEnabled Boolean    @default(false)
  twoFactorSecret  String?    @db.VarChar(255)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?
  deletedByType    ActorType?
  deletedById      String?    @db.Uuid

  // Relations deferred to their owning milestone (docs/AUTH_SCHEMA_REVIEW.md
  // Section 4): employee (M4), auditLogs/activityLogs/apiKeysCreated (M9),
  // customerNotesAuthored/filesUploaded (M4), assignedConversations/
  // messagesSent (M6), notifications (M9).
  tenant                          Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  roles                           UserRole[]
  sessions                        RefreshToken[]
  passwordResets                  PasswordReset[]
  emailVerifications              EmailVerification[]
  invitationsSent                 TenantInvitation[]         @relation("InvitedBy")
  auditLogs                       AuditLog[]
  employee                        Employee?
  appointmentStatusHistoryActions AppointmentStatusHistory[]

  @@index([tenantId], name: "idx_users_tenant_id")
  @@map("users")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        RoleName @unique
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]
  invitations TenantInvitation[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], name: "uq_role_permissions_role_permission")
  @@index([permissionId], name: "idx_role_permissions_permission_id")
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId], name: "uq_user_roles_user_role")
  @@index([roleId], name: "idx_user_roles_role_id")
  @@map("user_roles")
}

model RefreshToken {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String?   @db.Uuid
  userId              String    @db.Uuid
  refreshTokenHash    String    @unique @db.VarChar(255)
  userAgent           String?   @db.VarChar(255)
  ipAddress           String?   @db.VarChar(45)
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedBySessionId String?   @db.Uuid
  createdAt           DateTime  @default(now())

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Self-referential rotation chain (docs/PRISMA_SCHEMA.md Section 3.1): the
  // old row is never deleted on rotation, only linked forward. onDelete is
  // explicit SetNull (not left to Prisma's implicit default for an optional
  // relation) so a pruned successor row breaks the forward pointer instead of
  // blocking the expiry-cleanup job's delete.
  replacedBySession RefreshToken?  @relation("TokenRotation", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  rotatedFrom       RefreshToken[] @relation("TokenRotation")

  @@index([userId], name: "idx_refresh_tokens_user_id")
  @@index([expiresAt], name: "idx_refresh_tokens_expires_at")
  @@map("refresh_tokens")
}

model EmailVerification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String?   @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique @db.VarChar(255)
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_email_verifications_user_id")
  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?   @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_password_resets_user_id")
  @@index([expiresAt], name: "idx_password_resets_expires_at")
  @@map("password_resets")
}

// --- Tenant Models (docs/PRISMA_SCHEMA.md Section 4) -----------------------
// Tenant is minimal — schema only (id/name/slug/status/timezone/address/
// locale/trial/suspension/audit columns). TenantSettings, TenantFeature, and
// every relation below other than `users`/`invitations` are deferred to
// Milestone 3's Tenants module, which builds on this table rather than
// creating it (docs/AUTH_SCHEMA_REVIEW.md Section 3, ADR-002). Pulled forward
// from Milestone 3 specifically because User.tenantId and TenantInvitation
// both require it to exist, and PRISMA_SCHEMA.md Section 14.2's own migration
// order already places Tenant (step 2) before Identity (step 4).

model Tenant {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String       @db.VarChar(255)
  slug          String       @unique @db.VarChar(100)
  status        TenantStatus @default(TRIAL)
  timezone      String       @default("UTC") @db.VarChar(50)
  addressLine1  String?      @db.VarChar(255)
  addressLine2  String?      @db.VarChar(255)
  city          String?      @db.VarChar(100)
  countryCode   String?      @db.Char(2)
  defaultLocale String       @default("en") @db.VarChar(10)
  trialEndsAt   DateTime?
  suspendedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  users             User[]
  invitations       TenantInvitation[]
  settings          TenantSettings?
  auditLogs         AuditLog[]
  salonProfile      SalonProfile?
  businessHours     BusinessHours[]
  holidays          Holiday[]
  employees         Employee[]
  serviceCategories ServiceCategory[]
  services          Service[]
  customers         Customer[]
  appointments      Appointment[]

  @@index([status], name: "idx_tenants_status")
  @@map("tenants")
}

// TenantSettings (Milestone 3, docs/TENANT_ARCHITECTURE.md): namespaced into
// five independently-extensible JSON blocks rather than flat columns, per
// the requester's explicit brief. Each namespace defaults to `{}` and is
// owned by whichever future milestone populates it (business/notifications
// wait on Scheduling/AI/Notifications; general/localization/security have no
// concrete fields yet) — adding a field to a namespace is an application-layer
// change, never a schema migration. This milestone only builds the
// container; no namespace is populated with real data yet.
model TenantSettings {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @unique @db.Uuid

  general       Json @default("{}")
  localization  Json @default("{}")
  business      Json @default("{}")
  notifications Json @default("{}")
  security      Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model TenantInvitation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  email           String    @db.VarChar(255)
  roleId          String    @db.Uuid
  invitedByUserId String    @db.Uuid
  tokenHash       String    @unique @db.VarChar(255)
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy User   @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId], name: "idx_tenant_invitations_tenant_id")
  @@index([email], name: "idx_tenant_invitations_email")
  @@map("tenant_invitations")
}

// --- Salon Models (Milestone 4, docs/SALON_ARCHITECTURE.md,
// docs/adr/ADR-007-salon-management.md) --------------------------------------
// SalonProfile is a 1:1 satellite table on Tenant, mirroring TenantSettings'
// precedent: Tenant already owns the "core" salon identity (name/timezone/
// address/locale, exposed via GET/PATCH /tenant since Milestone 3) — this
// table holds only the genuinely new business-facing fields Milestone 4
// introduces. `logoUrl` is a bare placeholder string (no Files/S3 module
// exists yet) — deliberately not reusing PRISMA_SCHEMA.md's reserved
// `Tenant.logoFileId` name/shape, so the eventual real Files-backed field
// doesn't collide with this milestone's placeholder.
//
// BusinessHours/Holiday intentionally use the field names/shapes
// docs/PRISMA_SCHEMA.md Section 4 already reserves for a future, broader
// Employee/Branch-aware version of these tables (no `employeeId`/`branchId`
// columns yet — those modules don't exist) — so a later milestone only adds
// columns, never renames. Holiday's `@@unique([tenantId, date])` is the
// correct constraint for this milestone's tenant-wide-only scope; adding
// `employeeId` later requires replacing it with a manual partial unique
// index (`WHERE employee_id IS NULL`), not a naive 3-column @@unique — see
// docs/SALON_ARCHITECTURE.md.

model SalonProfile {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @unique @db.Uuid
  description    String?  @db.VarChar(1000)
  contactEmail   String?  @db.VarChar(255)
  contactPhone   String?  @db.VarChar(20)
  website        String?  @db.VarChar(255)
  currency       String   @default("USD") @db.Char(3)
  logoUrl        String?  @db.VarChar(500)
  primaryColor   String?  @db.VarChar(7)
  secondaryColor String?  @db.VarChar(7)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("salon_profiles")
}

model BusinessHours {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  dayOfWeek Int      @db.SmallInt // 0=Sunday..6=Saturday
  startTime DateTime @db.Time
  endTime   DateTime @db.Time
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dayOfWeek], name: "uq_business_hours_tenant_day")
  @@map("business_hours")
}

model Holiday {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  date      DateTime @db.Date
  reason    String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date], name: "uq_holidays_tenant_date")
  @@map("holidays")
}

// --- Workforce & Service Catalog Models (Milestone 5, docs/WORKFORCE_
// ARCHITECTURE.md, docs/SERVICE_ARCHITECTURE.md, docs/adr/ADR-008-workforce-
// and-service-catalog.md) ---------------------------------------------------
// Employee is a schedulable staff resource, distinct from User login access
// (an Employee may optionally link to a User via userId). ServiceCategory/
// Service form the catalog. EmployeeService is the first real consumer of
// the composite-FK cross-tenant pattern (docs/TENANT_ARCHITECTURE.md
// Section 4.1, PRISMA_SCHEMA.md Section 14.4) — Employee/Service each carry
// a compound @@unique([tenantId, id]) so EmployeeService's relations can be
// declared as compound FKs (fields: [tenantId, xId], references:
// [tenantId, id]), expressible natively in Prisma without a manual SQL edit.
// EmployeeTimeOff is a new, dedicated model for per-employee leave — kept
// separate from the existing tenant-wide Holiday table (Milestone 4) rather
// than extending Holiday with a nullable employeeId, so Milestone 4's
// shipped schema/migration/tests remain untouched (ADR-008).

model Employee {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String         @db.Uuid
  userId        String?        @unique @db.Uuid
  firstName     String         @db.VarChar(100)
  lastName      String         @db.VarChar(100)
  phoneNumber   String?        @db.VarChar(20)
  status        EmployeeStatus @default(ACTIVE)
  colorTag      String?        @db.VarChar(7)
  bio           String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  deletedByType ActorType?
  deletedById   String?        @db.Uuid

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  services            EmployeeService[]
  workingHours        WorkingHours[]
  timeOff             EmployeeTimeOff[]
  appointments        Appointment[]
  appointmentServices AppointmentService[]

  @@unique([tenantId, id], name: "uq_employees_tenant_id")
  @@index([tenantId, status], name: "idx_employees_tenant_status")
  @@map("employees")
}

model ServiceCategory {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  name         String    @db.VarChar(100)
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([tenantId], name: "idx_service_categories_tenant_id")
  @@map("service_categories")
}

model Service {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid
  categoryId        String?   @db.Uuid
  name              String    @db.VarChar(150)
  description       String?   @db.Text
  durationMinutes   Int
  priceCents        Int
  currency          String    @default("USD") @db.Char(3)
  bufferTimeMinutes Int       @default(0)
  isActive          Boolean   @default(true)
  displayOrder      Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category            ServiceCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  employees           EmployeeService[]
  appointmentServices AppointmentService[]

  @@unique([tenantId, id], name: "uq_services_tenant_id")
  @@index([tenantId, isActive], name: "idx_services_tenant_active")
  @@map("services")
}

model EmployeeService {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  employeeId String   @db.Uuid
  serviceId  String   @db.Uuid
  createdAt  DateTime @default(now())

  // Compound FKs against each side's (tenantId, id) composite unique —
  // the composite-FK cross-tenant pattern (docs/TENANT_ARCHITECTURE.md
  // Section 4.1): the database itself rejects linking an employeeId/
  // serviceId pair that belong to two different tenants, not just the
  // application layer.
  employee Employee @relation(fields: [tenantId, employeeId], references: [tenantId, id], onDelete: Cascade)
  service  Service  @relation(fields: [tenantId, serviceId], references: [tenantId, id], onDelete: Cascade)

  @@unique([employeeId, serviceId], name: "uq_employee_services_employee_service")
  @@index([serviceId], name: "idx_employee_services_service_id")
  @@index([tenantId], name: "idx_employee_services_tenant_id")
  @@map("employee_services")
}

model WorkingHours {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  employeeId String   @db.Uuid
  dayOfWeek  Int      @db.SmallInt // 0=Sunday..6=Saturday
  startTime  DateTime @db.Time
  endTime    DateTime @db.Time
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, dayOfWeek], name: "idx_working_hours_employee_day")
  @@map("working_hours")
}

model EmployeeTimeOff {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  employeeId String   @db.Uuid
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  reason     String?  @db.VarChar(255)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId], name: "idx_employee_time_off_tenant_employee")
  @@map("employee_time_off")
}

// --- Customer Models (Milestone 6, docs/adr/ADR-009-scheduling-engine.md) --
// Deliberately scoped down from PRISMA_SCHEMA.md's full Customer domain:
// CustomerTag/CustomerNote/CustomerPreference are not built this milestone
// (not requested — only "Customer CRUD" was asked for) and remain open for a
// future pass, same "narrow the ask, log the deferral" precedent ADR-008 set
// for Files/Customers itself. No createdByType/createdById/updatedByType/
// updatedById columns — mirrors the as-built Employee/Service precedent
// (Milestone 5 dropped these in favor of the dedicated audit trail; for
// Appointment, AppointmentStatusHistory is that trail, so duplicating actor
// attribution as plain columns here would be redundant, not defense in depth).

model Customer {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String     @db.Uuid
  phoneNumber       String     @db.VarChar(20)
  firstName         String?    @db.VarChar(100)
  lastName          String?    @db.VarChar(100)
  email             String?    @db.VarChar(255)
  preferredLanguage String?    @db.VarChar(10)
  marketingOptIn    Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?
  deletedByType     ActorType?
  deletedById       String?    @db.Uuid

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  // Plain (tenantId, phoneNumber) index here — the partial unique
  // (`WHERE deletedAt IS NULL`) is a manual migration edit, docs/PRISMA_
  // SCHEMA.md Section 14.4's established mechanism, since two rows may
  // legitimately share a phone number once one is soft-deleted.
  @@unique([tenantId, id], name: "uq_customers_tenant_id")
  @@index([tenantId, phoneNumber], name: "idx_customers_tenant_phone")
  @@map("customers")
}

// --- Appointment Models (Milestone 6, docs/adr/ADR-009-scheduling-engine.md,
// docs/SCHEDULING_ARCHITECTURE.md) ------------------------------------------
// Per-service employee assignment (confirmed decision, ADR-009): a single
// visit can have different services performed by different employees in
// sequence. Appointment.employeeId is therefore a *denormalized "primary"*
// value (the first sequenceOrder line's employeeId — convenient for simple
// `filter[employeeId]` queries and calendar display), never authoritative
// for conflict/availability — AppointmentService rows are. Each
// AppointmentService line carries its own computed [startTime, endTime)
// sub-window (sequential, no gap, within one continuous visit) plus
// `blockedUntil` (endTime + effective buffer) and `isBlocking` (kept in sync
// with the parent Appointment's status in the same transaction) so the
// database-level EXCLUDE constraint and the availability engine can operate
// per employee-line rather than per whole-appointment.

model Appointment {
  id                           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                     String            @db.Uuid
  customerId                   String            @db.Uuid
  employeeId                   String            @db.Uuid
  status                       AppointmentStatus @default(CONFIRMED)
  startTime                    DateTime
  endTime                      DateTime
  totalPriceCents              Int
  currency                     String            @default("USD") @db.Char(3)
  notes                        String?           @db.Text
  cancellationReason           String?           @db.VarChar(255)
  cancelledAt                  DateTime?
  rescheduledFromAppointmentId String?           @db.Uuid
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt
  deletedAt                    DateTime?
  deletedByType                ActorType?
  deletedById                  String?           @db.Uuid

  tenant          Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer                   @relation(fields: [tenantId, customerId], references: [tenantId, id], onDelete: Restrict)
  employee        Employee                   @relation(fields: [tenantId, employeeId], references: [tenantId, id], onDelete: Restrict)
  // onDelete: Restrict, not SetNull — this is a composite FK sharing the
  // required `tenantId` column with two other relations on this same row
  // (customer/employee); SetNull would attempt to null `tenantId` itself,
  // which is never valid (Prisma warns on this). Restrict is also the
  // semantically correct choice: an appointment that's been rescheduled
  // *into* should never be removable while the row it superseded still
  // points at it.
  rescheduledFrom Appointment?               @relation("RescheduleChain", fields: [tenantId, rescheduledFromAppointmentId], references: [tenantId, id], onDelete: Restrict)
  rescheduledTo   Appointment[]              @relation("RescheduleChain")
  services        AppointmentService[]
  statusHistory   AppointmentStatusHistory[]

  @@unique([tenantId, id], name: "uq_appointments_tenant_id")
  @@index([tenantId, employeeId, startTime], name: "idx_appointments_tenant_employee_start")
  @@index([tenantId, customerId], name: "idx_appointments_tenant_customer")
  @@index([tenantId, status, startTime], name: "idx_appointments_tenant_status_start")
  @@map("appointments")
}

model AppointmentService {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String   @db.Uuid
  appointmentId           String   @db.Uuid
  serviceId               String   @db.Uuid
  employeeId              String   @db.Uuid
  serviceNameSnapshot     String   @db.VarChar(150)
  durationMinutesSnapshot Int
  priceCentsSnapshot      Int
  bufferMinutesSnapshot   Int      @default(0)
  sequenceOrder           Int      @default(0) @db.SmallInt
  startTime               DateTime
  endTime                 DateTime
  blockedUntil            DateTime
  isBlocking              Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  // appointmentId is a plain (non-composite) FK — this is parent/child
  // ownership (same precedent as WorkingHours -> Employee), not a relation
  // between two independent tenant-owned entities, so the composite-FK
  // pattern doesn't apply here. service/employee ARE independent tenant-
  // owned entities relative to this junction, so both use the composite-FK
  // pattern (docs/TENANT_ARCHITECTURE.md Section 4.1).
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [tenantId, serviceId], references: [tenantId, id], onDelete: Restrict)
  employee    Employee    @relation(fields: [tenantId, employeeId], references: [tenantId, id], onDelete: Restrict)

  @@index([appointmentId], name: "idx_appointment_services_appointment_id")
  @@index([serviceId], name: "idx_appointment_services_service_id")
  @@index([tenantId, employeeId, startTime], name: "idx_appointment_services_tenant_employee_start")
  @@map("appointment_services")
}

// Append-only (docs/PRISMA_SCHEMA.md Section 7.1 precedent) — no update/
// delete call is ever made against this model. `id` uses standard
// `gen_random_uuid()`, not app-generated UUIDv7 — this codebase already
// made and documented this exact call for `AuditLog` ("not worth a new
// dependency at this milestone's volume... a deferred follow-up, not an
// oversight"); this table follows the same precedent rather than
// introducing the only UUIDv7 dependency in the project for one more
// table at comparable volume.
model AppointmentStatusHistory {
  id            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String                   @db.Uuid
  appointmentId String                   @db.Uuid
  action        AppointmentHistoryAction
  previousState Json?
  newState      Json
  actorType     ActorType
  actorId       String?                  @db.Uuid
  createdAt     DateTime                 @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actor       User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([appointmentId], name: "idx_appointment_status_history_appointment_id")
  @@index([tenantId, createdAt], name: "idx_appointment_status_history_tenant_created")
  @@map("appointment_status_history")
}

// --- System / Audit Models (Milestone 3 pull-forward from Milestone 9;
// docs/TENANT_ARCHITECTURE.md, docs/adr/ADR-006) ----------------------------
// AuditLog is deliberately platform-wide and reusable, not a tenant-specific
// table: `tenantId`/`entityId`/`actorId` are all nullable so the same table
// can record tenant-scoped business events (settings changed, invitation
// created) *and* platform-level events with no single owning tenant (a
// Super Admin listing tenants, a future cross-tenant action). Only the
// events this milestone actually writes (tenant lifecycle, settings,
// invitations, admin tenant-switch) exist yet — every other module adds its
// own `action`/`entityType` values as it's built, never a schema change.
// `id` uses standard `gen_random_uuid()` rather than PRISMA_SCHEMA.md's
// recommended app-generated UUIDv7 for this table — that optimization
// targets 10M+-row index locality (Milestone 9 territory) and isn't worth a
// new dependency at this milestone's volume; noted as a deferred follow-up,
// not an oversight.
model AuditLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String?   @db.Uuid
  action     String    @db.VarChar(100)
  entityType String    @db.VarChar(100)
  entityId   String?   @db.Uuid
  actorType  ActorType
  actorId    String?   @db.Uuid
  metadata   Json?
  ipAddress  String?   @db.VarChar(45)
  createdAt  DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor  User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt], name: "idx_audit_logs_tenant_created")
  @@index([entityType, entityId], name: "idx_audit_logs_entity")
  @@index([action], name: "idx_audit_logs_action")
  @@map("audit_logs")
}

// --- Billing Models (docs/PRISMA_SCHEMA.md Section 10) ---------------------
// Subscription/Invoice/Payment/Coupon are deferred to Milestone 8 — Plan has
// no dependency on them (its back-relation to Subscription is added when
// Subscription's migration lands).

model Plan {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String   @db.VarChar(50)
  stripePriceId       String   @unique @db.VarChar(100)
  monthlyPriceCents   Int
  currency            String   @default("USD") @db.Char(3)
  maxStaff            Int?
  maxMessagesPerMonth Int?
  maxLocations        Int      @default(1)
  isActive            Boolean  @default(true)
  trialDays           Int      @default(14)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isActive], name: "idx_plans_is_active")
  @@map("plans")
}
